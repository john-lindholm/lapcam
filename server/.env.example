# Server Configuration
PORT=8080
WSS_PORT=8443

# Domain
DOMAIN=sec.sigma-chat.biz

# SSL Certificate paths (use Let's Encrypt in production)
SSL_CERT_PATH=/etc/ssl/certs/lapcam.crt
SSL_KEY_PATH=/etc/ssl/private/lapcam.key

# Authentication
ADMIN_PASSWORD=change-me-in-production
JWT_SECRET=generate-a-secure-secret-key-here

# AWS Configuration
AWS_REGION=us-east-1
S3_BUCKET=lapcam-recordings-your-account-id

# Database
DATABASE_PATH=/var/lib/lapcam/lapcam.db

# Recording
RECORDING_ENABLED=true
RECORDING_SEGMENT_DURATION=10
BUFFER_DIR=/tmp/lapcam-server-buffer

# Logging
LOG_LEVEL=info
